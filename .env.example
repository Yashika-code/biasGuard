# BiasGuard backend environment template
# Copy values into your deployment environment (Render dashboard),
# not into committed files.

# Required for Gemini calls
GEMINI_API_KEY=

# Required on Render unless GOOGLE_APPLICATION_CREDENTIALS points to a file
# Paste the FULL service-account JSON as a single-line JSON string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Recommended explicit project and bucket values
FIREBASE_PROJECT_ID=biasguard-42ac2
FIREBASE_STORAGE_BUCKET=biasguard-42ac2.appspot.com

# PORT is provided automatically by Render.
# Do not set PORT manually.
