rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can only upload and read their own CSV files
    match /uploads/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Demo datasets are publicly readable
    match /demo/{allPaths=**} {
      allow read: if true;
      allow write: if false;  // Only service account writes demo files
    }
  }
}
